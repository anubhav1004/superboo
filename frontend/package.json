{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "description": "Superboo web and macOS client",
  "author": "Anubhav Mishra",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:desktop": "tsc -b && vite build --mode desktop --base ./ --outDir dist-desktop",
    "dev:desktop": "concurrently -k \"npm run dev:desktop:web\" \"npm run dev:desktop:shell\"",
    "dev:desktop:shell": "wait-on tcp:4173 && electron .",
    "dev:desktop:web": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "lint": "eslint .",
    "pack:mac": "npm run build:desktop && electron-builder --mac dir --publish never",
    "dist:mac": "npm run build:desktop && electron-builder --mac dmg --publish never",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "rehype-highlight": "^7.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.superboo.desktop",
    "productName": "Superboo",
    "asar": true,
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "files": [
      "dist-desktop/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
